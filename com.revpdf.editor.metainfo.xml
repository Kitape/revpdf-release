<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.revpdf.editor</id>
  <metadata_license>MIT</metadata_license>
  <project_license>LicenseRef-proprietary</project_license>

  <name>RevPDF Editor</name>
  <developer id="com.revpdf">
    <name>Pawandeep Singh</name>
  </developer>
  <summary>Edit. Annotate. Export. Privately.</summary>

  <description>
    <p>
      RevPDF Editor is a powerful, lightweight PDF editor that runs entirely on your device.
      No cloud uploads, no account needed, no subscriptions — your documents stay private.
    </p>
    <ul>
      <li>Edit text and images directly in PDF files</li>
      <li>Draw, highlight, and annotate PDFs</li>
      <li>Redact sensitive content permanently</li>
      <li>Fill out forms and add electronic signatures</li>
      <li>Split, merge, and reorganize pages</li>
      <li>Compress, watermark, and convert PDFs</li>
      <li>On-device OCR to make scanned PDFs searchable</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.revpdf.editor.desktop</launchable>

  <url type="homepage">https://revpdf.com/</url>
  <url type="license">https://revpdf.com/license</url>
  <url type="bugtracker">https://github.com/Pawandeep-prog/revpdf-release/issues</url>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/Pawandeep-prog/revpdf-release/main/images/home.png</image>
      <caption>RevPDF Editor home screen</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Pawandeep-prog/revpdf-release/main/images/edit.png</image>
      <caption>Editing and annotating a PDF document</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Pawandeep-prog/revpdf-release/main/images/tools.png</image>
      <caption>Drawing, text, and redaction tools</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Pawandeep-prog/revpdf-release/main/images/scanner.png</image>
      <caption>On-device OCR scanner to make PDFs searchable</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="4.0.0" date="2025-05-05">
      <description>
        <p>Latest release of RevPDF Editor.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1"/>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>

  <recommends>
    <display_length compare="ge">768</display_length>
  </recommends>
</component>
